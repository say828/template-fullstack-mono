{
  "schema_version": 1,
  "name": "replace-service-name",
  "spec": {
    "planning_paths": [
      "sdd/01_planning",
      "sdd/02_plan"
    ],
    "canonical_targets_dir": "sdd/02_plan"
  },
  "frontend": {
    "default_target": "web",
    "targets": {
      "web": {
        "dir": "client/web",
        "adapter_path": "client/web/scripts/ui-parity-app-adapter.mjs",
        "screens_path": "client/web/src/lib/specScreens.json",
        "routes_path": "client/web/src/lib/specRouteCatalog.json",
        "preview_url": "http://127.0.0.1:4173",
        "parity_contract_path": "sdd/02_plan/10_test/templates/ui_parity_web_contract.yaml",
        "route_gap_output": "sdd/02_plan/99_generated/from_planning/ui_parity/ui_parity_web_route_gap_report.json",
        "route_gap_markdown_output": "sdd/02_plan/99_generated/from_planning/ui_parity/ui_parity_web_route_gap_report.md",
        "proof_output": "sdd/03_verify/10_test/ui_parity/web_agentic_dev_latest.json"
      }
    }
  },
  "commands": {
    "plan_audit": "bash sdd/99_toolchain/01_automation/agentic-dev/run_frontend_target.sh route_gap .",
    "build": "bash sdd/99_toolchain/01_automation/agentic-dev/run_frontend_target.sh build .",
    "proof": "bash sdd/99_toolchain/01_automation/agentic-dev/run_frontend_target.sh proof .",
    "deploy_dev": "echo 'Template repo does not ship a deploy workflow.' >&2; exit 1",
    "verify_dev": "test -f \"$PWD/sdd/03_verify/10_test/ui_parity/web_agentic_dev_latest.json\" && echo dev-verify-ok"
  },
  "agentic": {
    "execution": {
      "claim_mode": "pm_dispatch",
      "dynamic_concurrency": true,
      "overlap_policy": "residual_issue",
      "lease_ttl_minutes": 120,
      "resource_watermarks": {
        "min_free_ram_bytes": 4294967296,
        "max_load_per_cpu": 1.0
      }
    },
    "validation_profiles": {
      "project": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build",
        "cd server && uv run --extra dev pytest -q"
      ],
      "specs": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build"
      ],
      "architecture": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build",
        "cd server && uv run --extra dev pytest -q"
      ],
      "ui": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build"
      ],
      "api": [
        "cd server && uv run --extra dev pytest -q"
      ],
      "runtime": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build",
        "cd server && uv run --extra dev pytest -q"
      ],
      "ci": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build",
        "cd server && uv run --extra dev pytest -q"
      ],
      "gitops": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build",
        "cd server && uv run --extra dev pytest -q"
      ],
      "security": [
        "cd server && uv run --extra dev pytest -q"
      ],
      "default": [
        "pnpm install --frozen-lockfile",
        "pnpm --dir client/web build",
        "cd server && uv run --extra dev pytest -q"
      ]
    },
    "delivery": {
      "dev_merge": "auto_after_green",
      "prod_merge": "auto_after_green",
      "prod_release_gate": "manual_argocd_sync_ack"
    }
  },
  "artifacts": {
    "route_gap_output": "sdd/02_plan/99_generated/from_planning/ui_parity/ui_parity_web_route_gap_report.json",
    "proof_output": "sdd/03_verify/10_test/ui_parity/web_agentic_dev_latest.json"
  },
  "notes": [
    "The canonical agentic-dev contract lives under sdd/99_toolchain/01_automation/agentic-dev to match the shared template layout.",
    "Route-gap artifacts are generated under sdd/02_plan/99_generated/from_planning/ui_parity and proof artifacts remain under sdd/03_verify/10_test/ui_parity.",
    "Frontend bootstrap targets only client/web in this fullstack mono layout.",
    "DEV deploy is intentionally workflow-only; repo-local manual recovery scripts are not part of the supported path."
  ]
}
