{
  "schema_version": 1,
  "feature_specs_glob": "sdd/01_planning/01_feature/*_feature_spec.md",
  "feature_todos_glob": "sdd/02_plan/01_feature/*_todos.md",
  "source_artifact_globs": [
    "sdd/01_planning/02_screen/ir/seller/seller_screen_spec.pdf",
    "sdd/01_planning/02_screen/ir/dealer/dealer_screen_spec.pdf",
    "sdd/01_planning/02_screen/ir/admin/admin_screen_spec.pdf",
    "sdd/01_planning/02_screen/guidelines/*.json",
    "sdd/02_plan/03_architecture/spec_traceability.md",
    "sdd/02_plan/10_test/ui_parity_contract.yaml"
  ],
  "screen_registry_globs": [
    "sdd/01_planning/02_screen/ir/seller/registry.json",
    "sdd/01_planning/02_screen/ir/dealer/registry.json",
    "sdd/01_planning/02_screen/ir/admin/registry.json"
  ],
  "screen_task_statuses": [
    "partial"
  ],
  "landing_exclude_prefixes": [],
  "ir": {
    "validate_command": "python3 sdd/99_toolchain/01_automation/validate_template_screen_ir.py",
    "regenerate_command": "python3 sdd/99_toolchain/01_automation/build_template_screen_ir.py"
  },
  "outputs": {
    "task_catalog": "sdd/99_toolchain/01_automation/github-project-kit/task-catalog.json",
    "task_sync_state": "sdd/99_toolchain/01_automation/github-project-kit/task-sync-state.json"
  }
}
